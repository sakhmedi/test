# =============================================================
# DocuFlow AI — Environment Variables Template
# Copy this file to .env and fill in your own values.
# =============================================================

# -------------------------------------------------------------
# PostgreSQL (shared instance — docuflow app + langfuse DBs)
# -------------------------------------------------------------
POSTGRES_USER=admin
POSTGRES_PASSWORD=change_me_postgres
POSTGRES_DB=test

# -------------------------------------------------------------
# Redis
# -------------------------------------------------------------
REDIS_URL=redis://redis:6379/0

# -------------------------------------------------------------
# MinIO (S3-compatible object storage)
# -------------------------------------------------------------
MINIO_USER=admin
MINIO_PASSWORD=change_me_minio
MINIO_ENDPOINT=minio:9000
MINIO_BUCKET=test-docs

# -------------------------------------------------------------
# Backend / FastAPI
# -------------------------------------------------------------
SECRET_KEY=change_me_secret_key_32_chars_min
DATABASE_URL=postgresql://admin:change_me_postgres@postgres:5432/test
ALLOWED_ORIGINS=http://localhost:3000

# -------------------------------------------------------------
# Milvus (vector database) — uses etcd for cluster metadata
# -------------------------------------------------------------
MILVUS_HOST=milvus
MILVUS_PORT=19530

# -------------------------------------------------------------
# RAGFlow — document AI engine
# -------------------------------------------------------------
RAGFLOW_API_URL=http://ragflow:9380
RAGFLOW_API_KEY=change_me_ragflow_api_key

# -------------------------------------------------------------
# Langfuse — LLM observability / tracing
# -------------------------------------------------------------
LANGFUSE_SECRET_KEY=change_me_langfuse_secret
LANGFUSE_PUBLIC_KEY=change_me_langfuse_public
LANGFUSE_HOST=http://langfuse:3000
LANGFUSE_DATABASE_URL=postgresql://admin:change_me_postgres@postgres:5432/langfuse
NEXTAUTH_SECRET=change_me_nextauth_secret
NEXTAUTH_URL=http://localhost:3001

# -------------------------------------------------------------
# AlemLLM — модели от школы
# -------------------------------------------------------------
ALEM_API_BASE_URL=https://...  # один базовый URL для всех

# Ключи по моделям
ALEMLLM_API_KEY=ключ_от_alemllm
QWEN3_API_KEY=ключ_от_qwen3

# Какую модель использовать по умолчанию
DEFAULT_MODEL=qwen3
