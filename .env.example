# =============================================================
# Shart AI — Environment Variables Template
# Copy this file to .env and fill in your own values.
# =============================================================

# -------------------------------------------------------------
# PostgreSQL (shared instance — shart app + n8n DBs)
# -------------------------------------------------------------
POSTGRES_USER=admin
POSTGRES_PASSWORD=change_me_postgres
POSTGRES_DB=shart

# -------------------------------------------------------------
# Redis
# -------------------------------------------------------------
REDIS_URL=redis://redis:6379/0

# -------------------------------------------------------------
# MinIO (S3-compatible object storage)
# -------------------------------------------------------------
MINIO_USER=admin
MINIO_PASSWORD=change_me_minio
MINIO_ENDPOINT=minio:9000
MINIO_BUCKET=shart-docs

# -------------------------------------------------------------
# Backend / FastAPI
# -------------------------------------------------------------
SECRET_KEY=change_me_secret_key_32_chars_min
JWT_SECRET=change_me_jwt_secret_32_chars_min
DATABASE_URL=postgresql://admin:change_me_postgres@postgres:5432/shart
ALLOWED_ORIGINS=http://localhost:3000

# -------------------------------------------------------------
# OCR — DeepSeek OCR model
# Uses the same LLM_API_URL base; only the key and model differ.
# -------------------------------------------------------------
OCR_API_KEY=change_me_ocr_api_key
OCR_MODEL=deepseek-ocr

# -------------------------------------------------------------
# STT — Kazakh speech-to-text
# -------------------------------------------------------------
STT_API_URL=https://placeholder-stt.api/v1/transcribe
STT_API_KEY=change_me_stt_api_key

# -------------------------------------------------------------
# Reranker — relevance scoring
# -------------------------------------------------------------
RERANKER_API_URL=https://placeholder-reranker.api/v1/rerank

# -------------------------------------------------------------
# Embedder
# -------------------------------------------------------------
EMBEDDER_API_URL=https://placeholder-embedder.api/v1/embed

# -------------------------------------------------------------
# Milvus (vector database) — uses etcd for cluster metadata
# -------------------------------------------------------------
MILVUS_HOST=milvus
MILVUS_PORT=19530

# -------------------------------------------------------------
# RAGFlow — document AI engine
# -------------------------------------------------------------
RAGFLOW_API_URL=http://ragflow:9380
RAGFLOW_API_KEY=change_me_ragflow_api_key

# -------------------------------------------------------------
# Langfuse — LLM observability / tracing (school-hosted)
# Get your keys from https://a1-langfuse1.alem.ai:
#   1. Log in → create a project → Settings → API Keys
#   2. Copy Secret Key and Public Key into your .env
# -------------------------------------------------------------
LANGFUSE_SECRET_KEY=change_me_langfuse_secret
LANGFUSE_PUBLIC_KEY=change_me_langfuse_public
LANGFUSE_HOST=https://a1-langfuse1.alem.ai

# -------------------------------------------------------------
# LLM — standardised vars (preferred)
# -------------------------------------------------------------
# FIXED: use these generic vars; old ALEM_*/QWEN3_* kept for backward-compat
LLM_API_URL=https://llm.alem.ai/v1
LLM_API_KEY=change_me_llm_api_key
LLM_MODEL=qwen3

# -------------------------------------------------------------
# AlemLLM — модели от школы (backward-compat, kept)
# -------------------------------------------------------------
ALEM_API_BASE_URL=https://...  # один базовый URL для всех

# Ключи по моделям
ALEMLLM_API_KEY=ключ_от_alemllm
QWEN3_API_KEY=ключ_от_qwen3

# Какую модель использовать по умолчанию
DEFAULT_MODEL=qwen3
